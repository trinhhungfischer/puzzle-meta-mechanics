generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model MechanicGroup {
  id          String     @id @default(cuid())
  name        String     @unique
  slug        String     @unique
  description String?
  mechanics   Mechanic[]
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}

model Mechanic {
  id          String         @id @default(cuid())
  name        String         @unique
  slug        String         @unique
  description String?
  iconUrl     String?
  mediaUrls   String? // Stored as JSON string
  constraints String? // Stored as JSON string
  groupId     String
  group       MechanicGroup  @relation(fields: [groupId], references: [id], onDelete: Cascade)
  games       GameMechanic[]
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
}

model Genre {
  id          String   @id @default(cuid())
  name        String   @unique
  slug        String   @unique
  description String?
  games       Game[] // Implicit m:n relation
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Platform {
  id        String         @id @default(cuid())
  name      String         @unique
  slug      String         @unique
  games     GamePlatform[]
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
}

model Game {
  id          String         @id @default(cuid())
  title       String         @unique
  slug        String         @unique
  releaseYear Int?
  description String?
  coverUrl    String?
  mechanics   GameMechanic[]
  genres      Genre[] // Implicit m:n relation
  platforms   GamePlatform[]
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
}

model GameMechanic {
  id         String   @id @default(cuid())
  gameId     String
  mechanicId String
  role       String // e.g. core, secondary, twist
  note       String?
  game       Game     @relation(fields: [gameId], references: [id], onDelete: Cascade)
  mechanic   Mechanic @relation(fields: [mechanicId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([gameId, mechanicId])
}

model GamePlatform {
  id         String   @id @default(cuid())
  gameId     String
  platformId String
  storeUrl   String?
  game       Game     @relation(fields: [gameId], references: [id], onDelete: Cascade)
  platform   Platform @relation(fields: [platformId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([gameId, platformId])
}
