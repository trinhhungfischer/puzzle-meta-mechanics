generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["relationJoins"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model MechanicGroup {
  id          String     @id @default(cuid())
  name        String     @unique
  slug        String     @unique
  description String?
  mechanics   Mechanic[]
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}

model Mechanic {
  id          String         @id @default(cuid())
  name        String         @unique
  slug        String         @unique
  description String?
  iconUrl     String?
  mediaUrls   String? // Stored as JSON string
  constraints String? // Stored as JSON string
  groupId     String
  group       MechanicGroup  @relation(fields: [groupId], references: [id], onDelete: Cascade)
  games       GameMechanic[]
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
}

model Genre {
  id          String   @id @default(cuid())
  name        String   @unique
  slug        String   @unique
  description String?
  games       Game[] // Implicit m:n relation
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Platform {
  id        String         @id @default(cuid())
  name      String         @unique
  slug      String         @unique
  games     GamePlatform[]
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
}

model Game {
  id          String         @id @default(cuid())
  title       String         @unique
  slug        String         @unique
  releaseYear Int?
  releaseDate DateTime?
  description String?
  coverUrl    String?

  // Review gate: crawled games land as "draft" (hidden from the public viewer)
  // and an admin publishes them. Manually created games default to "published".
  status String @default("published") //  "draft" | "published"

  // Aggregate metrics for filtering/sorting (US-024).
  // These are blended, per-game rollups. When the crawler lands (US-025),
  // per-store values may live on GamePlatform with these kept as the aggregate.
  ratingScore   Float? //  normalized 0-100
  ratingCount   Int?
  downloads     Int?
  reviewCount   Int?
  price         Float? //  in USD; null = unknown
  isFree        Boolean   @default(false)
  lastCrawledAt DateTime? //  provenance: when metrics were last refreshed

  mechanics GameMechanic[]
  genres    Genre[] // Implicit m:n relation
  platforms GamePlatform[]
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  @@index([ratingScore])
  @@index([downloads])
  @@index([isFree])
  @@index([status])
}

model GameMechanic {
  id         String   @id @default(cuid())
  gameId     String
  mechanicId String
  role       String // e.g. core, secondary, twist
  note       String?
  game       Game     @relation(fields: [gameId], references: [id], onDelete: Cascade)
  mechanic   Mechanic @relation(fields: [mechanicId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([gameId, mechanicId])
}

// Raw-crawl staging (ADR 0009): unnormalized source payloads land here first,
// then an ETL step promotes chosen fields into Game. Never queried by the app UI.
model CrawlRecord {
  id          String    @id @default(cuid())
  source      String //  "steam"
  sourceId    String //  e.g. Steam appid
  kind        String //  "appdetails" | "reviews" | "steamspy"
  payload     Json //     raw response (jsonb)
  fetchedAt   DateTime  @default(now())
  processedAt DateTime? //  set when ETL has consumed it
  error       String? //   ETL/fetch error, if any

  @@unique([source, sourceId, kind])
  @@index([source, processedAt])
}

model GamePlatform {
  id         String   @id @default(cuid())
  gameId     String
  platformId String
  storeUrl   String?
  game       Game     @relation(fields: [gameId], references: [id], onDelete: Cascade)
  platform   Platform @relation(fields: [platformId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([gameId, platformId])
}
